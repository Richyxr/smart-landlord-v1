# Smart Landlord environment template
#
# Local demo defaults:
# - frontend demo mode is enabled automatically during `npm run client`
# - backend demo mode is enabled automatically unless NODE_ENV=production or DEMO_MODE=false
#
# Production safety:
# - set NODE_ENV=production
# - do not set DEMO_MODE=true
# - do not set VITE_DEMO_MODE=true

# Server
NODE_ENV=development
PORT=5000
DEMO_MODE=true
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=86400
DATA_BACKEND=json

# Frontend
# true: show demo auto-login/dev switcher
# false: force normal auth screen even in local development
VITE_DEMO_MODE=true

# DATABASE_URL=postgres://user:password@host:5432/smart_landlord
# DATABASE_SSL=false
# AUTH_PROVIDER=firebase
# AUTH_PROJECT_ID=
# CORS_ORIGIN=https://app.smartlandlord.example

# Secret Management (Phase 7)
# ENCRYPTION_KEY must be a random, high-entropy 32+ character string for production.
# Used for encrypting/decrypting organization integration credentials at rest (AES-256-GCM).
# REQUIRED in production (NODE_ENV=production). In development, a fallback is used if omitted.
# ENCRYPTION_KEY=

# Webhook security (Phase 6)
# Per-organization webhook secrets are stored in organization_integrations.webhook_secret.
# The columns below on organization_integrations control routing and validation:
#   shortcode           — M-Pesa shortcode/paybill (routes inbound callbacks to the owning org)
#   account_reference   — Expected M-Pesa account reference prefix
#   webhook_secret      — M-Pesa passkey (STK), callback URL token (C2B), or HMAC secret (bank)
#   provider_identifier — Bank code or partner ID for non-M-Pesa integrations
#
# Provider-specific callback URLs to register with providers:
#   M-Pesa C2B:  https://<domain>/api/webhooks/mpesa/c2b?token=<webhook_secret>
#   M-Pesa STK:  https://<domain>/api/webhooks/mpesa/stk
#   Bank:        https://<domain>/api/webhooks/bank  (X-Webhook-Signature: HMAC-SHA256)
#   Generic:     https://<domain>/api/webhooks/payment (backward-compatible, auto-detects provider)
#
# Legacy single-org fallback (not recommended for multi-tenant production):
# MPESA_WEBHOOK_SECRET=

# Email delivery is dashboard-managed.
# Configure Platform Email in Super Admin and optional landlord custom SMTP in Settings.
# Do not configure SMTP credentials via runtime environment variables.
# APP_PUBLIC_URL is still infrastructure runtime config.
# APP_PUBLIC_URL=https://app.smartlandlord.example
